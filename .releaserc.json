{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/npm",
      {
        "npmPublish": true
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          { "path": "dist/canvas-kit.js", "label": "canvas-kit.js" },
          { "path": "dist/index.d.ts", "label": "index.d.ts" }
        ]
      }
    ]
  ]
}
