{
  "name": "@geekybones/canvas-kit",
  "version": "1.0.0",
  "description": "CanvasKit — a modular canvas runtime built on PixiJS v8. Compose only the features you need — elements, history, camera, snap, alignment, serialization, and more.",
  "author": "Manoj Kumar <manoj@geekybones.com>",
  "license": "MIT",
  "homepage": "https://geekybones.github.io/canvas-kit/",
  "repository": {
    "type": "git",
    "url": "https://github.com/geekybones/canvas-kit"
  },
  "bugs": {
    "url": "https://github.com/geekybones/canvas-kit/issues"
  },
  "keywords": [
    "canvas",
    "canvas-kit",
    "pixi",
    "pixijs",
    "webgl",
    "webgpu",
    "graphics",
    "design-tool",
    "text-effects",
    "vector",
    "typescript"
  ],
  "packageManager": "pnpm@10.26.1",
  "type": "module",
  "module": "./dist/canvas-kit.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/canvas-kit.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": ">=3.1.2"
    }
  },
  "scripts": {
    "build": "vite build",
    "build:types": "tsc --emitDeclarationOnly",
    "build:playground": "pnpm build && pnpm --dir playground build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "dev:playground": "pnpm --dir playground dev",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "pixi.js": "^8.16.0"
  },
  "dependencies": {
    "earcut": "^3.0.2",
    "eventemitter3": "^5.0.4",
    "opentype.js": "^2.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^25.7.0",
    "@types/opentype.js": "^1.3.9",
    "@vitest/coverage-v8": "^4.1.6",
    "jsdom": "^29.1.1",
    "pixi.js": "^8.18.1",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.6"
  }
}
